# Copie para .env e preencha com valores fortes e únicos.
# NUNCA versione o arquivo .env real.

# === MySQL ===
MYSQL_DATABASE=origem_wp
MYSQL_USER=origem
MYSQL_PASSWORD=troque-por-senha-forte-aleatoria
MYSQL_ROOT_PASSWORD=troque-por-senha-root-ainda-mais-forte

# === WordPress ===
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=origem_wp
WORDPRESS_DB_USER=origem
WORDPRESS_DB_PASSWORD=troque-por-senha-forte-aleatoria
WORDPRESS_TABLE_PREFIX=ogm_

# Gere chaves únicas em: https://api.wordpress.org/secret-key/1.1/salt/
WORDPRESS_AUTH_KEY=
WORDPRESS_SECURE_AUTH_KEY=
WORDPRESS_LOGGED_IN_KEY=
WORDPRESS_NONCE_KEY=
WORDPRESS_AUTH_SALT=
WORDPRESS_SECURE_AUTH_SALT=
WORDPRESS_LOGGED_IN_SALT=
WORDPRESS_NONCE_SALT=

# === Ambiente ===
WORDPRESS_DEBUG=0

# === Integração Google Sheets (formulário de contato) ===
# 1) Crie uma planilha no Google Drive
# 2) Em Extensões > Apps Script, cole o conteúdo de docs/google-sheets-apps-script.js
# 3) Implemente como Web App: Executar como "Eu" / Acesso "Qualquer pessoa"
# 4) Copie a URL final (terminada em /exec) abaixo
# 5) Gere um token aleatório (32+ caracteres) e coloque o mesmo valor no script
ORIGEM_SHEETS_WEBHOOK_URL=
ORIGEM_SHEETS_TOKEN=
